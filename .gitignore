# Secrets -- never commit API keys
.env
 
# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
build/
dist/
 
# Jupyter
.ipynb_checkpoints/
 
# Editor / OS
.DS_Store
.vscode/
*.code-workspace
 
# Personal working resources (assignment PDF, extra/raw materials)
