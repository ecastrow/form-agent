resources/
 
# Sample form images are excluded out of caution around PII, even
# though the samples used are believed synthetic/fictitious -- the
# directory itself stays tracked (via .gitkeep) so the expected
# project structure is visible; real samples are shared separately
# (see README).
data/*
!data/.gitkeep
